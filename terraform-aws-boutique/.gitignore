# --- Local Terraform Directories ---
# Contains downloaded modules and providers (very large, do not commit)
.terraform/

# --- Terraform State Files ---
# These contain sensitive infrastructure data and should be in S3, not Git
*.tfstate
*.tfstate.*

# --- Crash Logs ---
# Generated if Terraform crashes
crash.log
crash.*.log

# --- Variable Files (SENSITIVE) ---
# Never commit actual credentials or secrets
*.tfvars
*.tfvars.json

# --- Override Files ---
# Used for local testing only
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# --- CLI Configuration ---
.terraformrc
terraform.rc
